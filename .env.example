# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com -> Your Cluster -> Connect -> Drivers
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/autonova?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/autonova?retryWrites=true&w=majority

# Your deployed site URL (no trailing slash)
# Example: https://autonova-motors.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
